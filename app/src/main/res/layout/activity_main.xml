<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="16dp"
    android:background="#212121"
    android:baselineAligned="false">

    <RelativeLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="110dp"
            android:layout_height="300dp"
            android:layout_centerInParent="true"
            app:cardBackgroundColor="#616161"
            app:cardCornerRadius="25dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="300dp"
            android:layout_height="120dp"
            android:layout_centerInParent="true"
            app:cardBackgroundColor="#616161"
            app:cardCornerRadius="25dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">
        </com.google.android.material.card.MaterialCardView>

        <View
            android:id="@+id/center_anchor"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_centerInParent="true"/>

        <Button
            android:id="@+id/btnForward"
            android:layout_width="75dp"
            android:layout_height="75dp"
            android:layout_above="@id/center_anchor"
            android:layout_centerHorizontal="true"
            android:layout_marginBottom="4dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="37.5dp"
            android:backgroundTint="#F5F5F5"
            android:text="▲"
            android:textColor="#212121"
            android:textSize="28sp" />

        <Button
            android:id="@+id/btnBackward"
            android:layout_width="75dp"
            android:layout_height="75dp"
            android:layout_below="@id/center_anchor"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="4dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="37.5dp"
            android:backgroundTint="#F5F5F5"
            android:text="▼"
            android:textColor="#212121"
            android:textSize="28sp" />

        <Button
            android:id="@+id/btnLeft"
            android:layout_width="75dp"
            android:layout_height="75dp"
            android:layout_toStartOf="@id/center_anchor"
            android:layout_centerVertical="true"
            android:layout_marginEnd="4dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="37.5dp"
            android:backgroundTint="#F5F5F5"
            android:text="◀"
            android:textColor="#212121"
            android:textSize="28sp" />

        <Button
            android:id="@+id/btnRight"
            android:layout_width="75dp"
            android:layout_height="75dp"
            android:layout_toEndOf="@id/center_anchor"
            android:layout_centerVertical="true"
            android:layout_marginStart="4dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="37.5dp"
            android:backgroundTint="#F5F5F5"
            android:text="▶"
            android:textColor="#212121"
            android:textSize="28sp" />

    </RelativeLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="연결 상태: 대기중"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="15dp"/>

        <Button
            android:id="@+id/btnConnect"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="블루투스 연결"
            android:backgroundTint="#2196F3"
            android:layout_marginBottom="10dp"/>



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnHeightUp"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="높이 UP"
                android:backgroundTint="#FF9800"
                android:layout_marginEnd="5dp"/>

            <Button
                android:id="@+id/btnHeightDown"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="높이 DOWN"
                android:backgroundTint="#FF9800"
                android:layout_marginStart="5dp"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>